# AdvantShop base URL — your connected domain (preferred) or technical store address
ADVANTSHOP_BASE_URL=http://shop.synonym-jewelry.ru
# ADVANTSHOP_BASE_URL=https://shop.synonym-jewelry.ru
# ADVANTSHOP_BASE_URL=https://s4.advantme.ru/437293-svmk
# Server API key — tab «API» (categories, orders, customers)
ADVANTSHOP_SERVER_API_KEY=your_server_api_key
# Legacy alias (optional if SERVER/CLIENT keys are set separately)
ADVANTSHOP_API_KEY=your_server_api_key

# Client API key — tab «API с авторизацией» (REQUIRED for catalog & products)
ADVANTSHOP_CLIENT_API_KEY=your_client_api_key

# Map storefront categories to AdvantShop category URL paths (last segment of category URL)
ADVANTSHOP_CATEGORY_MAP={"rings":"koltso","earrings":"sergi","pendants":"kole","bracelets":"braslet"}
# Amvera (no quotes allowed in env values):
# ADVANTSHOP_CATEGORY_MAP=rings:koltso,earrings:sergi,pendants:kole,bracelets:braslet

# Optional cookie for technical-domain stores in «under development» mode
# ADVANTSHOP_STORE_COOKIE=your_store_session_cookie

# Cache catalog responses (seconds)
ADVANTSHOP_REVALIDATE_SECONDS=300

# AdvantShop HTTP timeout (ms). Increase if the shop is slow on cold start.
# ADVANTSHOP_FETCH_TIMEOUT_MS=55000

# Optional order source label in AdvantShop admin
# ADVANTSHOP_ORDER_SOURCE=synonym-jewelry.ru

# Site URL for payment return links
SITE_URL=https://synonym-jewelry.ru

# Search engine verification (meta tags in <head>)
# Google Search Console: HTML tag method → paste only the content value
# GOOGLE_SITE_VERIFICATION=your_google_verification_token
# Yandex Webmaster: defaults to 98707ef5a3ae9578 (HTML file is also in /public)
# YANDEX_SITE_VERIFICATION=98707ef5a3ae9578

# YooKassa online payments (https://yookassa.ru)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
# Optional custom return URL (orderId is appended automatically)
# YOOKASSA_RETURN_URL=https://synonym-jewelry.ru/checkout/success

# Photta virtual try-on widget (https://photta.app)
# NEXT_PUBLIC_PHOTTA_API_KEY=pk_live_your_key

# Amvera: use port 80 (platform default) and bind all interfaces
# PORT=80
# HOSTNAME=0.0.0.0
